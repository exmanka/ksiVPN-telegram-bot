# PostgreSQL container environment variables
DOTENV_POSTGRES_IMAGE="postgres"
DOTENV_POSTGRES_TAG="17.9-alpine3.23"
DOTENV_POSTGRES_PORT="54320"

# PostgreSQL connection settings
DOTENV_POSTGRES_USER="ksivpn-tgbot"
DOTENV_POSTGRES_PASSWORD="ksivpn-tgbot"
DOTENV_POSTGRES_DB="ksivpn-tgbot"

# Redis connection settings
DOTENV_REDIS_PASSWORD="ksivpn-tgbot"

# General settings
DOTENV_TZ="Europe/Moscow"

# Telegram bot container environment variables
DOTENV_TGBOT_IMAGE="ksivpn-tgbot"
DOTENV_TGBOT_TAG="local"
DOTENV_TGBOT_ENV="default"
DOTENV_TGBOT_PROXY_ENABLED="false"
DOTENV_TGBOT_PROXY_URL=""
DOTENV_TGBOT_BOT_TOKEN=""                       # [!]
DOTENV_TGBOT_YOOMONEY_TOKEN=""                  # [!]
DOTENV_TGBOT_YOOMONEY_ACCOUNT=""                # [!]
DOTENV_TGBOT_YOOMONEY_NOTIFICATION_SECRET=""    # [!] HMAC-SHA256 secret from YooMoney wallet HTTP-notifications
DOTENV_TGBOT_YOOKASSA_SHOP_ID=""                # [!]
DOTENV_TGBOT_YOOKASSA_SECRET_KEY=""             # [!]
DOTENV_TGBOT_PAYMENTS_RETURN_URL="https://t.me/ksiVPN_bot"
DOTENV_TGBOT_WEBHOOK_PORT="8080"
DOTENV_TGBOT_WEBHOOK_PUBLIC_BASE_URL=""
DOTENV_TGBOT_ADMIN_ID=""                        # [!]
DOTENV_TGBOT_PAYMENTS_TEST_USER_IDS="[]"
DOTENV_TGBOT_PAYMENTS_TEST_PRICE="2"
DOTENV_TGBOT_LOCALIZATION_LANGUAGE="en"
DOTENV_TGBOT_REDIS_FSM_PREFIX="ksivpn_aiogram_fsm"
DOTENV_TGBOT_REMNAWAVE_BASE_URL=""              # [!]
DOTENV_TGBOT_REMNAWAVE_TOKEN=""                 # [!]
DOTENV_TGBOT_REMNAWAVE_CADDY_TOKEN=""

# Caddy container environment variables
DOTENV_CADDY_DOMAIN=""                          # [!] FQDN that resolves to this host
DOTENV_CADDY_ACME_EMAIL=""                      # [!] contact email for Let's Encrypt
