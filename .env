# PostgreSQL container environment variables
DOTENV_POSTGRES_IMAGE="${CI_REGISTRY_IMAGE:+${CI_REGISTRY_IMAGE:-''}/}ksivpn-tgbot-postgres"
DOTENV_POSTGRES_TAG="${GITLAB_TAG:-local}"
DOTENV_POSTGRES_ADDITIONAL_LANGUAGE="ru_RU"
DOTENV_POSTGRES_INITDB_ARGS="--locale=en_US.UTF-8 --lc-time=ru_RU.UTF-8"
DOTENV_POSTGRES_PORT="${GITLAB_POSTGRES_PORT:-54320}"

# PostgreSQL connection settings
DOTENV_POSTGRES_USER="${GITLAB_POSTGRES_USER:-ksivpn-tgbot}"
DOTENV_POSTGRES_PASSWORD="${GITLAB_POSTGRES_PASSWORD:-ksivpn-tgbot}"
DOTENV_POSTGRES_DB="${GITLAB_POSTGRES_DB:-ksivpn-tgbot}"

# General settings
DOTENV_TZ="Europe/Moscow"

# Telegram bot container environment variables
DOTENV_TGBOT_IMAGE="${CI_REGISTRY_IMAGE:+${CI_REGISTRY_IMAGE:-''}/}ksivpn-tgbot"
DOTENV_TGBOT_TAG="${GITLAB_TAG:-local}"
DOTENV_TGBOT_BOT_TOKEN="${GITLAB_TGBOT_BOT_TOKEN:-0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX}"
DOTENV_TGBOT_PROXY_URL="${GITLAB_TGBOT_PROXY_URL}"
DOTENV_TGBOT_YOOMONEY_TOKEN="${GITLAB_TGBOT_YOOMONEY_TOKEN:-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX...}"
DOTENV_TGBOT_YOOMONEY_ACCOUNT="${GITLAB_TGBOT_YOOMONEY_ACCOUNT:-000000000000000}"
DOTENV_TGBOT_ADMIN_ID="${GITLAB_TGBOT_ADMIN_ID:-000000000}"
DOTENV_TGBOT_BACKUP_PATH="${GITLAB_TGBOT_BACKUP_PATH:-/usr/src/tgbot/backups}"
DOTENV_TGBOT_LOCALIZATION_LANGUAGE="${GITLAB_TGBOT_LOCALIZATION_LANGUAGE:-en}"
