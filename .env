# PostgreSQL container environment variables
DOTENV_POSTGRES_IMAGE="ksivpn-tgbot-postgres"
DOTENV_POSTGRES_TAG="local"
DOTENV_POSTGRES_ADDITIONAL_LANGUAGE="ru_RU"
DOTENV_POSTGRES_INITDB_ARGS="--locale=en_US.UTF-8 --lc-time=ru_RU.UTF-8"
DOTENV_POSTGRES_PORT="54320"

# PostgreSQL connection settings
DOTENV_POSTGRES_USER="ksivpn-tgbot"
DOTENV_POSTGRES_PASSWORD="ksivpn-tgbot"
DOTENV_POSTGRES_DB="ksivpn-tgbot"

# Redis connection settings
DOTENV_REDIS_PASSWORD="ksivpn-tgbot"

# General settings
DOTENV_TZ="Europe/Moscow"

# Telegram bot container environment variables
DOTENV_TGBOT_IMAGE="ksivpn-tgbot"
DOTENV_TGBOT_TAG="local"
DOTENV_TGBOT_PROXY_URL=""
DOTENV_TGBOT_BOT_TOKEN=""           # [!]
DOTENV_TGBOT_YOOMONEY_TOKEN=""      # [!]
DOTENV_TGBOT_YOOMONEY_ACCOUNT=""    # [!]
DOTENV_TGBOT_ADMIN_ID=""            # [!]
DOTENV_TGBOT_BACKUP_PATH="/usr/src/tgbot/backups"
DOTENV_TGBOT_LOCALIZATION_LANGUAGE="en"
DOTENV_TGBOT_REDIS_FSM_PREFIX="ksivpn_aiogram_fsm"
